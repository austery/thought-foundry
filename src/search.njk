---
title: "搜索"
layout: "base.njk"
permalink: /search/
eleventyExcludeFromCollections: true
---

<div class="search-page-container" data-pagefind-ignore>
  <h1 class="search-page-title">搜索</h1>
  <div id="search-full"></div>
</div>

<script>
  window.addEventListener('DOMContentLoaded', () => {
    new PagefindUI({
      element: "#search-full",
      showSubResults: true,
      showImages: false,
      excerptLength: 20,
      translations: {
        placeholder: "搜索文章...",
        clear_search: "清除",
        load_more: "加载更多结果",
        search_label: "搜索此站点",
        filters_label: "过滤器",
        zero_results: "没有找到 [SEARCH_TERM] 的结果",
        many_results: "[COUNT] 个结果关于 [SEARCH_TERM]",
        one_result: "[COUNT] 个结果关于 [SEARCH_TERM]",
        alt_search: "没有找到 [SEARCH_TERM] 的结果。显示 [DIFFERENT_TERM] 的结果：",
        search_suggestion: "没有找到 [SEARCH_TERM] 的结果。尝试以下搜索之一：",
        searching: "搜索 [SEARCH_TERM]..."
      }
    });

    const _q = new URLSearchParams(window.location.search).get('q');
    if (_q) {
      setTimeout(() => {
        const input = document.querySelector('#search-full .pagefind-ui__search-input');
        if (input) {
          input.value = _q;
          input.dispatchEvent(new Event('input', { bubbles: true }));
        }
      }, 100);
    }
  });
</script>
