<!DOCTYPE html>
<html lang="zh-Hans">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title }}</title>

    <!-- 字体：Playfair Display (英文展示) + Noto Serif SC (中文) + JetBrains Mono (代码/元数据) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Noto+Serif+SC:wght@600;700&family=Noto+Sans+SC:wght@400;500&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="{{ '/css/main.css' | url }}" />
    <link href="{{ '/pagefind/pagefind-ui.css' | url }}" rel="stylesheet">
  </head>
  <body>
    <div class="page-wrapper">

      <header class="site-header">
        <!-- 品牌标志 -->
        <a class="site-brand" href="{{ '/' | url }}">
          <span class="site-brand__glyph">◆</span>
          <strong class="site-brand__en">The Learning Grove</strong>
          <span class="site-brand__zh">林间拾穗</span>
        </a>

        <!-- 主导航 -->
        <nav class="main-nav" aria-label="主导航">
          <ul>
            <li><a href="{{ '/' | url }}">首页</a></li>
            <li><a href="{{ '/all-areas/' | url }}">领域</a></li>
            <li><a href="{{ '/all-categories/' | url }}">分类</a></li>
            <li><a href="{{ '/all-projects/' | url }}">专题</a></li>
            <li><a href="{{ '/all-tags/' | url }}">标签</a></li>
            <li><a href="{{ '/all-speakers/' | url }}">演讲者</a></li>
            <li><a href="http://localhost:3333" target="_blank" rel="noopener">🔍 语义搜索</a></li>
            <li><a href="{{ '/tool/' | url }}">工具</a></li>
            <li><a href="{{ '/bookshelf/' | url }}">书架</a></li>
            <li><a href="{{ '/about/' | url }}">关于</a></li>
          </ul>
        </nav>

        <!-- 右侧控件：搜索 + 主题切换 -->
        <div class="search-container">
          <div id="search"></div>
          <button id="theme-toggle" class="theme-toggle" title="切换主题" aria-label="切换深色/浅色主题">
            <span class="theme-toggle-icon">🌙</span>
          </button>
        </div>
      </header>

      <main class="site-content">
        {{ content | safe }}
      </main>

      <footer class="site-footer">
        <p>&copy; 2025 Austery &nbsp;·&nbsp; All rights reserved.</p>
      </footer>

    </div>

    <script>
      const site_url = "{{ '/' | url }}";
    </script>
    <script src="{{ '/js/theme-toggle.js' | url }}"></script>
    <script src="{{ '/pagefind/pagefind-ui.js' | url }}"></script>
    <script>
      window.addEventListener('DOMContentLoaded', (event) => {
        new PagefindUI({
          element: "#search",
          showSubResults: true,
          showImages: false,
          excerptLength: 15,
          translations: {
            placeholder: "搜索文章...",
            clear_search: "清除",
            load_more: "加载更多结果",
            search_label: "搜索此站点",
            filters_label: "过滤器",
            zero_results: "没有找到 [SEARCH_TERM] 的结果",
            many_results: "[COUNT] 个结果关于 [SEARCH_TERM]",
            one_result: "[COUNT] 个结果关于 [SEARCH_TERM]",
            alt_search: "没有找到 [SEARCH_TERM] 的结果。显示 [DIFFERENT_TERM] 的结果：",
            search_suggestion: "没有找到 [SEARCH_TERM] 的结果。尝试以下搜索之一：",
            searching: "搜索 [SEARCH_TERM]..."
          }
        });
      });
    </script>
  </body>
</html>
